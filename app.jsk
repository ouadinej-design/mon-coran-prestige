<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lecteur Coran - Al-Murshid</title>
    <style>
        /* Styles de base pour faire propre */
        body { font-family: Arial, sans-serif; background-color: #f4f4f9; padding: 20px; }
        .lecteur-container { background: white; max-width: 400px; margin: 0 auto; padding: 20px; border-radius: 12px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); text-align: center; }
        select, input[type="range"] { width: 100%; padding: 10px; margin: 15px 0; border-radius: 6px; border: 1px solid #ccc; }
        .boutons { display: flex; justify-content: space-between; gap: 10px; margin-bottom: 20px; }
        button { flex: 1; padding: 12px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; color: white; }
        .btn-play { background-color: #28a745; }
        .btn-pause { background-color: #ffc107; color: black; }
        .btn-stop { background-color: #dc3545; }
        label { font-weight: bold; }
    </style>
</head>
<body>

<div class="lecteur-container">
    <h2>Lecteur Al-Murshid</h2>

    <select id="listeImams">
        <option value="https://server8.mp3quran.net/afs/">Mishary Rashid Alafasy</option>
        <option value="https://server11.mp3quran.net/sds/">Abdurrahmaan As-Sudais</option>
        <option value="https://server7.mp3quran.net/basit/">Abdul Basit (Murattal)</option>
    </select>

    <select id="listeSourates">
        <option value="001">1. Al-Fatihah</option>
        <option value="002">2. Al-Baqarah</option>
        <option value="112">112. Al-Ikhlas</option>
        <option value="113">113. Al-Falaq</option>
        <option value="114">114. An-Nas</option>
        </select>

    <div class="boutons">
        <button class="btn-play" onclick="jouerAudio()">▶ Play</button>
        <button class="btn-pause" onclick="pauseAudio()">⏸ Pause</button>
        <button class="btn-stop" onclick="stopAudio()">⏹ Stop</button>
    </div>

    <div>
        <label>Vitesse : <span id="valeurVitesse">1.0</span>x</label>
        <input type="range" id="vitesseAudio" min="0.5" max="2.0" step="0.1" value="1.0" oninput="changerVitesse()">
    </div>

    <audio id="lecteurAudio" src=""></audio>
</div>

<script>
    // Récupération des éléments de la page
    const lecteur = document.getElementById('lecteurAudio');
    const listeImams = document.getElementById('listeImams');
    const listeSourates = document.getElementById('listeSourates');
    const vitesseAudio = document.getElementById('vitesseAudio');
    const valeurVitesse = document.getElementById('valeurVitesse');

    // Fonction pour fabriquer le lien audio (Imam + Numéro Sourate + .mp3)
    function mettreAJourSource() {
        const urlImam = listeImams.value;
        const numSourate = listeSourates.value;
        lecteur.src = urlImam + numSourate + ".mp3";
    }

    // Fonction PLAY
    function jouerAudio() {
        // Si aucune source n'est chargée, on la prépare
        if (!lecteur.src || lecteur.src === window.location.href) {
            mettreAJourSource();
        }
        lecteur.play();
    }

    // Fonction PAUSE
    function pauseAudio() {
        lecteur.pause();
    }

    // Fonction STOP
    function stopAudio() {
        lecteur.pause();
        lecteur.currentTime = 0; // Ramène la lecture à 0 seconde
    }

    // Fonction pour le régulateur de VITESSE
    function changerVitesse() {
        lecteur.playbackRate = vitesseAudio.value; // Modifie la vitesse réelle
        valeurVitesse.innerText = vitesseAudio.value; // Affiche le chiffre à l'écran
    }

    // Bonus : Si on change d'Imam ou de Sourate pendant la lecture, ça relance le bon fichier
    listeImams.addEventListener('change', () => { mettreAJourSource(); jouerAudio(); });
    listeSourates.addEventListener('change', () => { mettreAJourSource(); jouerAudio(); });

</script>

</body>
</html>
